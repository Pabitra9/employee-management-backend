# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
# NOTE: macOS uses port 5000 for AirPlay Receiver, so we default to 5050.
PORT=5050
NODE_ENV=development

# Comma-separated list of allowed CORS origins. Use * to allow all (dev only).
# Covers Create-React-App (3000) and Vite (5173) dev servers.
CLIENT_URL=http://localhost:3000,http://localhost:5173

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# Local:  mongodb://127.0.0.1:27017/employee_management
# Atlas:  mongodb+srv://<user>:<password>@<cluster>/employee_management
MONGO_URI=mongodb://127.0.0.1:27017/employee_management

# ----------------------------------------------------------------------------
# Authentication (JWT)
# ----------------------------------------------------------------------------
# Use a long, random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# ----------------------------------------------------------------------------
# Password reset
# ----------------------------------------------------------------------------
# Base URL of the React app. Reset links look like:
#   <FRONTEND_URL>/reset-password/<token>
FRONTEND_URL=http://localhost:5173

# SMTP for sending reset emails. LEAVE BLANK for local dev — the reset link is
# logged to the console (and returned by the API in non-production) instead.
# Example (Gmail app password / Mailtrap / SendGrid, etc.):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Employee Mgmt <no-reply@example.com>

# ----------------------------------------------------------------------------
# Seed credentials (used by `npm run seed`)
# ----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_EMPLOYEE_EMAIL=employee@example.com
SEED_EMPLOYEE_PASSWORD=Employee@123
